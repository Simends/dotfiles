#!/usr/bin/env bash

#   TODO oppdatere speil,

read_news() {
    case "$(echo '"Arch news"\n"Artix news"\n"Arch forum"\n"Artix forum"\n"Arch bugtracker"\n"Artix troubleshooting-guide"' | smenu -l -N -d -m "System news")" in
        "Arch news") surf https://archlinux.org/news/ ;;
        "Artix news") surf https://artixlinux.org/news.php ;;
        "Arch forum") surf https://bbs.archlinux.org/ ;;
        "Artix forum") surf https://forum.artixlinux.org/ ;;
        "Arch bugtracker") surf https://bugs.archlinux.org/ ;;
        "Artix troubleshooting-guide") surf https://wiki.artixlinux.org/Main/Troubleshooting ;;
    esac
}

case "$(echo '"List System Updates" "Update System" "Update AUR-packages" "Package stats" "Failed Services" "Service stats" "Clean Pacman-cache" "Clean .cache" "Delete Orphaned Packages" "Update Keyrings" "Empty Trash" "Read Logs" "Read News"' | smenu -t 3 -d -N -m "System maintenance")" in
    "List System Updates") checkupdates ;;
    "Update System") sudo pacman -Syyu ;;
    "Update AUR-packages") yay -Syu ;;
    "Package stats") yay -P -s ;;
    "Failed Services") /home/simen/.local/bin/servprober.sh ;;
    "Service stats") /home/simen/.local/bin/ssm.sh ;;
    "Clean Pacman-cache") paccache -rk1 -ruk0 ;;
    "Clean .cache") rm -vrf /home/simen/.cache/* && echo "Cache has been cleaned!" ;;
    "Delete Orphaned Packages") pacman -Qdt | awk '{print $1}' | xargs -ro sudo pacman -Rns ;;
    "Update Keyrings") echo "Installing new keyrings..." && pacman -Sy archlinux-keyring artix-keyring && echo "Removing old keyrings..." && rm -r /etc/pacman.d/gnupg && echo "Initializing new keyrings..." && pacman-key --init && echo "Updating the system..." && pacman -Scc && pacman -Syyu && echo "Finished" ;;
    "Empty Trash") rm -vrf /home/simen/.local/share/Trash/* && echo "Trash has been dealt with!" ;;
    "Read Logs") nnn /var/log/ ;;
    "Read News") read_news ;;
esac
