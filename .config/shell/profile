export NNN_BMS='S:/home/simen/Programs/Suckless/;k:/home/simen/Programs/Sources/linux/linux-5.10.7/;h:/home/simen/;s:/home/simen/Programs/Scripts/;c:/home/simen/.config/;D:/home/simen/Downloads/;v:/home/simen/Multimedia/Videos/;m:/home/simen/Multimedia/Music/;p:/home/simen/Multimedia/Pictures/;d:/home/simen/Documents/;'
